# Django
DJANGO_SECRET_KEY=replace-with-a-random-secret

# Music Strategy: suno | replicate | mock (default: suno)
MUSIC_STRATEGY=suno

# SunoAPI
SUNO_API_KEY=replace-with-your-sunoapi-key
SUNO_API_URL=https://api.sunoapi.org/api/v1
SUNO_MODEL=V4_5ALL
SUNO_CALLBACK_URL=https://example.com/callback

# Replicate (fallback)
REPLICATE_API_KEY=replace-with-your-replicate-token
REPLICATE_MUSICGEN_VERSION=671ac645ce5e552cc63a54a2bbff63fcf798043055d2dac5fc9e36a837eedcfb

# Google OAuth2
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here
